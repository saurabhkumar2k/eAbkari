                    "type": "string"
                  },
                  "SubDivision": {
                    "type": "string"
                  },
                  "PanNo": {
                    "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
                    "type": "string"
                  },
                  "photo": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "RegId": {
                  "style": "form"
                },
