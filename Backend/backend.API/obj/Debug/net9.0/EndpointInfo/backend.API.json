                    "minLength": 6,
                    "type": "string"
                  },
                  "Mobile": {
                    "maxLength": 10,
                    "minLength": 10,
                    "type": "string",
                    "format": "tel"
                  },
                  "Email": {
                    "maxLength": 256,
                    "minLength": 0,
                    "type": "string",
                    "format": "email"
                  },
                  "SecretQuestionId": {
                    "type": "integer",
